{
  "name": "elysium-creative-studio",
  "private": true,
  "version": "1.0.0",
  "description": "Elysium Creative Studio — Unlimited canvas with persistent storage for diagrams and sketches",
  "author": "Raghvendra",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "node scripts/patch-excalidraw-fonts.cjs",
    "patch-fonts": "node scripts/patch-excalidraw-fonts.cjs",
    "dev:web": "vite --config vite.web.config.ts",
    "build:web": "tsc -b && vite build --config vite.web.config.ts",
    "preview:web": "vite preview --config vite.web.config.ts",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "tsc -b && vite build && npx @electron/packager . \"Elysium Creative Studio\" --platform=win32 --arch=x64 --out=release --overwrite --icon=public/app_icon.ico --ignore=\"(release|src|\\.git|node_modules/\\.cache)\" --asar",
    "electron:preview": "electron ."
  },
  "build": {
    "appId": "com.elysium.creative-studio",
    "productName": "Elysium Creative Studio",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/app_icon.ico"
    ],
    "win": {
      "icon": "public/app_icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/app_icon.ico",
      "uninstallerIcon": "public/app_icon.ico",
      "installerHeaderIcon": "public/app_icon.ico"
    }
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.0",
    "idb-keyval": "^6.2.2",
    "lodash": "^4.17.23",
    "perfect-freehand": "^1.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "@eslint/js": "^9.39.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "electron": "^33.4.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^8.0.3"
  }
}
